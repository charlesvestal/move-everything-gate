{
  "id": "gate",
  "name": "GATE",
  "abbrev": "GT",
  "version": "0.1.0",
  "description": "Noise gate and downward expander",
  "author": "charlesvestal",
  "license": "MIT",
  "dsp": "gate.so",
  "api_version": 2,
  "capabilities": {
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "GATE",
          "params": [
            {
              "key": "threshold",
              "label": "Threshold",
              "type": "float",
              "min": -80.0,
              "max": 0.0,
              "default": -40.0,
              "step": 1.0,
              "unit": "dB"
            },
            {
              "key": "attack",
              "label": "Attack",
              "type": "float",
              "min": 0.1,
              "max": 50.0,
              "default": 3.0,
              "step": 0.1,
              "unit": "ms"
            },
            {
              "key": "hold",
              "label": "Hold",
              "type": "float",
              "min": 0.0,
              "max": 500.0,
              "default": 50.0,
              "step": 1.0,
              "unit": "ms"
            },
            {
              "key": "release",
              "label": "Release",
              "type": "float",
              "min": 10.0,
              "max": 1000.0,
              "default": 200.0,
              "step": 1.0,
              "unit": "ms"
            },
            {
              "key": "range",
              "label": "Range",
              "type": "float",
              "min": 0.0,
              "max": 80.0,
              "default": 80.0,
              "step": 1.0,
              "unit": "dB"
            },
            {
              "key": "ratio",
              "label": "Ratio",
              "type": "float",
              "min": 1.0,
              "max": 20.0,
              "default": 4.0,
              "step": 0.5,
              "unit": ":1"
            },
            {
              "key": "hysteresis",
              "label": "Hysteresis",
              "type": "float",
              "min": 0.0,
              "max": 12.0,
              "default": 4.0,
              "step": 0.5,
              "unit": "dB"
            },
            {
              "key": "mode",
              "label": "Mode",
              "type": "enum",
              "options": [
                "GATE",
                "EXPAND"
              ],
              "default": "GATE"
            }
          ],
          "knobs": [
            "threshold",
            "attack",
            "hold",
            "release",
            "range",
            "ratio",
            "hysteresis",
            "mode"
          ]
        }
      }
    }
  }
}
